# VocabuRex Chatbot Service Configuration (Docker Environment)
# This file is used when running in Docker containers

# Gemini AI Configuration
GEMINI_API_KEY=AIzaSyDJlpdOyy67E8t3QR9iEYk2q9j0-L-NYQI
GEMINI_MODEL=gemini-1.5-flash

# Service Configuration
SERVICE_NAME=vocabu-rex-chatbot-service
SERVICE_VERSION=1.0.0
SERVICE_HOST=0.0.0.0
SERVICE_PORT=3006

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# Deep Link Configuration
FLUTTER_APP_SCHEME=vocaburex
FLUTTER_APP_HOST=chatbot

# Educational Context
MAX_CONVERSATION_HISTORY=50
DEFAULT_LEARNING_LEVEL=intermediate

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# External Services (Docker network)
USER_SERVICE_URL=http://user-service:3002
LEARNING_SERVICE_URL=http://learning-service:3003
SPEECH_SERVICE_URL=http://speech-service:3005

# MongoDB Configuration (Docker)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=vocabu_rex_chatbot