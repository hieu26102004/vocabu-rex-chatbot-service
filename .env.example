# VocabuRex Chatbot Service Configuration

# Gemini AI Configuration
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.5-flash

# Service Configuration
SERVICE_NAME=vocabu-rex-chatbot-service
SERVICE_VERSION=1.0.0
SERVICE_HOST=localhost
SERVICE_PORT=3006

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# Deep Link Configuration
FLUTTER_APP_SCHEME=vocaburex
FLUTTER_APP_HOST=chatbot

# Educational Context
MAX_CONVERSATION_HISTORY=50
DEFAULT_LEARNING_LEVEL=intermediate

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# External Services (Optional for future integration)
USER_SERVICE_URL=http://localhost:3002
LEARNING_SERVICE_URL=http://localhost:3003
SPEECH_SERVICE_URL=http://localhost:3005

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=vocabu_rex_chatbot